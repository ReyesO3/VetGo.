@page
@model VetGo.Pages.Account.ForgotPasswordConfirmationModel

<h1>Enlace enviado</h1>
<p>Si existe una cuenta con ese correo, se ha enviado un enlace para restablecer la contraseña.</p>

@if (TempData["DevResetLink"] != null)
{
    <div class="alert alert-info">
        <strong>Enlace de desarrollo:</strong>
        <div>@Html.Raw(TempData["DevResetLink"].ToString())</div>
    </div>
}