@page
@model VetGo.Pages.LoginModel
@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="login-container">
    <!-- Reemplazo: usar la segunda imagen y ocultar el selector de rol "Dueño" -->
    <div class="login-card">
        <h2>Iniciar sesión</h2>

        <form method="post">
            <div class="form-group">
                <label asp-for="Input.Email">Correo electrónico</label>
                <input asp-for="Input.Email" />
            </div>
            <div class="form-group">
                <label asp-for="Input.Password">Contraseña</label>
                <input asp-for="Input.Password" type="password" />
            </div>
            <div class="form-group">
                <label>
                    <input asp-for="Input.RememberMe" /> Recordarme
                </label>
            </div>

            <button type="submit">Iniciar sesión</button>
        </form>

        <p><a asp-page="/Account/ForgotPassword">¿Olvidaste tu contraseña?</a></p>
        <p><a asp-page="/Register">¿No tienes cuenta? Regístrate</a></p>
    </div>

    <div class="login-image">
        <!-- Segunda imagen subida por el usuario -->
        <img src="/images/login-secondary.png" alt="Login image" />
    </div>
</div>

<style>
    /* Estilos básicos para que quede similar a la segunda imagen (simple y sin color) */
    .login-container { display:flex; gap:20px; padding:20px; }
    .login-card { background:white; padding:20px; border-radius:4px; box-shadow:0 0 0 rgba(0,0,0,0); }
    .login-image img { max-width:200px; }
    label { display:block; margin-top:8px; }
</style>
