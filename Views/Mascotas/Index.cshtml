@model IEnumerable<VetGo.Models.Mascota>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .card-mascota {
        border-radius: 15px;
        padding: 15px;
        background-color: #f8f9fc;
        box-shadow: 0px 2px 5px rgba(0,0,0,0.1);
        margin-bottom: 20px;
    }

    .img-mascota {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        object-fit: cover;
    }

    .badge-canino { background-color: #f0ad4e; }
    .badge-felino { background-color: #d6b3ff; }
    .btn-eliminar { background-color: #f8d7da; color: #842029; }
    .btn-editar { background-color: #e2e3e5; }
</style>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h3>Mis Mascotas</h3>
            <p class="text-muted">Administra la información de tus mascotas</p>
        </div>

        <a asp-action="Create" class="btn btn-primary">+ Agregar Mascota</a>
    </div>

    <!-- LISTADO -->
    @foreach (var item in Model)
    {
        var tipo = item.Especie?.ToLower();
        var claseBadge = tipo == "perro" ? "badge-canino" : "badge-felino";

        <div class="card-mascota d-flex align-items-center">

            <img src="https://via.placeholder.com/60" class="img-mascota me-3">

            <div class="flex-grow-1">
                <h6 class="mb-1">
                    @item.Nombre
                    <span class="badge @claseBadge">@item.Especie</span>
                </h6>

                <small>@item.Especie - @item.Raza</small><br>

                <small>
                    @{
                        var edad = DateTime.Now.Year - item.FechaNacimiento.Year;
                    }
                    @edad años - @item.PesoActual kg
                </small>
            </div>

            <div>
                <a asp-action="Edit" asp-route-id="@item.IdMascota" class="btn btn-sm btn-editar me-2">✏️ Editar</a>
                <a asp-action="Details" asp-route-id="@item.IdMascota" class="btn btn-sm btn-info me-2">👁 Ver</a>
                <a asp-action="Delete" asp-route-id="@item.IdMascota" class="btn btn-sm btn-eliminar">🗑 Eliminar</a>
            </div>
        </div>
    }

</div>
