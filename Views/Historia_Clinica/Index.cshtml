@model IEnumerable<VetGo.Models.Historia_Clinica>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .card-mascota { border-radius: 15px; padding: 10px; width: 120px; text-align: center; background: #fff; margin-right: 15px; border: 2px solid transparent; }
    .card-mascota.active { border: 2px solid #0d6efd; }
    .img-mascota { width: 60px; height: 60px; border-radius: 50%; object-fit: cover; }
    .historial-card { border-radius: 12px; padding: 20px; margin-bottom: 20px; }
    .bg-chequeo { background-color: #d4edda; }
    .bg-vacuna { background-color: #e6d9f7; }
</style>

<div class="container mt-4">

    <!-- MASCOTAS (visual) -->
    <div class="d-flex mb-4">
        <div class="card-mascota active">
            <img src="https://placedog.net/100" class="img-mascota">
            <strong>Max</strong><br>
            <small>Perro</small>
        </div>

        <div class="card-mascota">
            <img src="https://placekitten.com/100" class="img-mascota">
            <strong>Luna</strong><br>
            <small>Gato</small>
        </div>
    </div>

    <!-- BOTONES -->
    <div class="text-center mb-4">
        <button class="btn btn-primary btn-sm">Historial Médico</button>
        <button class="btn btn-light btn-sm">Vacunas</button>
        <button class="btn btn-light btn-sm">Recetas</button>
    </div>

    <h5>Historial Médico</h5>
    <small class="text-muted">Registro completo de consultas</small>

    <!-- LISTA DINÁMICA -->
    <div class="mt-3">

        @foreach (var item in Model)
        {
            var tipo = item.Diagnostico.ToLower().Contains("vacuna") ? "bg-vacuna" : "bg-chequeo";

            <div class="historial-card @tipo">

                <div class="d-flex justify-content-between">
                    <strong>@item.Diagnostico</strong>

                    <span class="badge bg-success">@item.FechaRegistro.ToString("dd MMM yyyy")</span>
                </div>

                <br />

                <small><strong>Tratamiento:</strong> @item.Tratamiento</small>
                <br />

                <small><strong>Fecha:</strong> @item.FechaRegistro.ToString("dd/MM/yyyy")</small>

                <div class="mt-3">
                    <a asp-action="Details" asp-route-id="@item.IdHistorial" class="btn btn-sm btn-primary">Ver Detalles</a>
                    <a asp-action="Edit" asp-route-id="@item.IdHistorial" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.IdHistorial" class="btn btn-sm btn-danger">Eliminar</a>
                </div>

            </div>
        }

    </div>

</div>
