@model IEnumerable<VetGo.Models.Usuario>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/vetgo_1/css/admin_rechazado.css" />

<header class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>VetGo Admin</h1>
        <p>Administrador</p>
    </div>
    <nav>
        <a asp-controller="Account" asp-action="Logout">Cerrar Sesión</a>
    </nav>
</header>

<main class="container mt-4">
    <section class="row mb-4">
        <article class="col-md-4 card p-3">
            <h2>Cuentas Pendientes</h2>
            <p>@(ViewData["TotalPending"] ?? 0)</p>
        </article>
        <article class="col-md-4 card p-3">
            <h2>Cuentas Aprobadas</h2>
            <p>@(ViewData["TotalApproved"] ?? 0)</p>
        </article>
        <article class="col-md-4 card p-3">
            <h2>Total de Cuentas</h2>
            <p>@(ViewData["TotalUsers"] ?? 0)</p>
        </article>
    </section>

    <nav class="mb-3">
        <a asp-action="Index">Pendientes (@(ViewData["TotalPending"] ?? 0))</a> |
        <a asp-action="Approved">Aprobadas (@(ViewData["TotalApproved"] ?? 0))</a> |
        <span class="font-weight-bold">Rechazadas (@(Model?.Count() ?? 0))</span>
    </nav>

    <section>
        @if (Model != null && Model.Any())
        {
            <ul class="list-unstyled">
                @foreach (var u in Model)
                {
                    <li class="card mb-3 p-3 d-flex justify-content-between align-items-start">
                        <div>
                            <h4>@u.Nombre</h4>
                            <p>@u.Email</p>
                            @if (u.Rol == "Veterinario" && !string.IsNullOrEmpty(u.Licencia))
                            {
                                <p>Licencia: @u.Licencia</p>
                            }
                            <p><span class="badge bg-secondary">@u.Rol</span></p>
                            <p class="estado-rechazado">Cuenta rechazada</p>
                        </div>

                        <div class="text-end">
                            <form asp-action="Approve" method="post" style="display:inline">
                                <input type="hidden" name="id" value="@u.Id" />
                                <button class="btn btn-success">Aprobar</button>
                            </form>

                            <form asp-action="DeletePermanently" method="post" style="display:inline; margin-left:8px">
                                <input type="hidden" name="id" value="@u.Id" />
                                <button class="btn btn-danger">Eliminar definitivamente</button>
                            </form>
                        </div>
                    </li>
                }
            </ul>
        }
        else
        {
            <p>No hay cuentas rechazadas.</p>
        }
    </section>
</main>
