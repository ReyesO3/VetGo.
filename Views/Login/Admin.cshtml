@{
    Layout = null;
    ViewData["Title"] = "VetGo - Inicio de Sesión Admin";
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/vetgo_1/css/login_forms.css" />
    <style>
        /* fallback styles (kept minimal) */
        body { background: linear-gradient(to right, #f1f7ff, #eef6ff); font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .left { flex:1 }
        .right { flex:1 }
    </style>
</head>
<body>
    <div class="container">
        <section class="left">
            <h2>Cuidado veterinario profesional al alcance de tu mano</h2>
        </section>

        <section class="right">
            <h3>Iniciar Sesión Admin</h3>
            <p>Ingresa a tu cuenta para continuar</p>

            <nav class="roles" style="margin:8px 0 12px 0;">
                <a class="btn-secondary" href="/Login">Dueño</a>
                <a href="/Login/Veterinario">Profesional</a>
                <a class="btn-secondary" href="/Login/Admin">Admin</a>
            </nav>

            <form method="post" id="loginForm" asp-action="Index" asp-controller="Login">
                @Html.AntiForgeryToken()
                <fieldset>
                    <label for="email">Email</label>
                    <input id="email" name="email" type="email" placeholder="admin@vetgo.com" required />
                </fieldset>

                <fieldset>
                    <label for="password">Contraseña</label>
                    <input id="password" name="password" type="password" placeholder="********" required />
                </fieldset>

                <fieldset>
                    <label>Código de verificación</label>
                    <article style="margin:6px 0;">
                        <span class="captcha-box" id="captcha">S S b G y 7</span>
                        <button type="button" id="refreshCaptcha" style="margin-left:8px">⟳</button>
                    </article>
                    <input id="captchaInput" name="captchaInput" type="text" placeholder="Ingresa el código" />
                </fieldset>

                <input type="hidden" name="role" value="Admin" />

                <div style="margin-top:12px;">
                    <button type="submit" class="btn-login">Iniciar Sesion</button>
                </div>
            </form>
        </section>
    </div>

    <script>
    function randomCaptcha(){
      const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789';
      let out = '';
      for(let i=0;i<6;i++){
        out += chars[Math.floor(Math.random()*chars.length)];
        if(i < 5) out += ' ';
      }
      return out;
    }

    const capBox = document.getElementById('captcha');
    const refresh = document.getElementById('refreshCaptcha');
    if(refresh && capBox) refresh.onclick = () => { capBox.textContent = randomCaptcha(); };

    const form = document.getElementById('loginForm');
    if(form){
      form.addEventListener('submit', function(e){
        const expected = capBox.textContent.replace(/\s/g,'');
        const typed = document.getElementById('captchaInput').value.replace(/\s/g,'');
        if(!typed){ alert('Por favor ingresa el código de verificación'); e.preventDefault(); return; }
        if(typed !== expected){ alert('Código incorrecto'); e.preventDefault(); }
      });
    }
    </script>
</body>
</html>
