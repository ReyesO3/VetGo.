@{
    Layout = null;
}

@model VetGo.Models.RegisterViewModel

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />

    <style>
            body {
                background: linear-gradient(to right, #dbeafe, #e0f2fe);
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            }

            .container {
                width: 420px;
                margin: 80px auto;
                background: #f8fafc;
                padding: 30px;
                border-radius: 12px;
                box-shadow: 0px 5px 20px rgba(0,0,0,0.1);
            }

            h2 {
                text-align: center;
                margin-bottom: 5px;
            }

            .subtitle {
                text-align: center;
                font-size: 13px;
                color: gray;
                margin-bottom: 20px;
            }

            /* BOTONES ROLES */
            .roles {
                display: flex;
                gap: 5px;
                margin-bottom: 20px;
            }

                .roles button {
                    flex: 1;
                    background-color: #2563eb;
                    color: white;
                    border: none;
                    padding: 8px;
                    border-radius: 6px;
                    cursor: pointer;
                }

            /* INPUTS */
            input {
                width: 100%;
                padding: 10px;
                margin-bottom: 12px;
                border-radius: 6px;
                border: 1px solid #ccc;
            }

            /* CAPTCHA */
            .captcha {
                background: #dbeafe;
                padding: 10px;
                text-align: center;
                border-radius: 6px;
                margin-bottom: 10px;
                letter-spacing: 5px;
            }

            /* BOTON LOGIN */
            .btn-login {
                width: 100%;
                background: #2563eb;
                color: white;
                padding: 10px;
                border: none;
                border-radius: 6px;
                cursor: pointer;
            }

                .btn-login:hover {
                    background: #1e40af;
                }

            /* LINKS */
            .links {
                text-align: center;
                margin-top: 15px;
                font-size: 12px;
            }

                .links a {
                    display: block;
                    color: #2563eb;
                    text-decoration: none;
                }
    </style>
</head>

<body>

    <div class="container">

        <h2>Crear Cuenta</h2>
        <p class="subtitle">Ingresa a tu cuenta para continuar</p>

        <!-- ROLES -->
        <div class="roles">
            <button type="button">Dueño</button>
            <button type="button">Profesional</button>
            <button type="button">Admin</button>
        </div>

        <!-- FORMULARIO -->
        <form method="post" asp-action="Register" asp-controller="Login">
            @Html.AntiForgeryToken()

            <div style="margin-bottom:12px;color:#b91c1c;">
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            </div>

            <label>Nombre</label>
            <input asp-for="Nombre" class="form-control" />

            <label>Email</label>
            <input asp-for="Email" class="form-control" />

            <label>Contraseña</label>
            <input asp-for="Password" type="password" class="form-control" />

            <label>Confirmar Contraseña</label>
            <input asp-for="ConfirmPassword" type="password" class="form-control" />

            <label>Tipo de usuario</label>
            <select asp-for="Rol" id="rolSelect" class="form-control">
                <option value="Usuario">Dueño</option>
                <option value="Veterinario">Profesional</option>
            </select>

            <div id="licenciaWrapper" style="display:none;">
                <label>Licencia profesional</label>
                <input asp-for="Licencia" class="form-control" placeholder="Número de licencia" />
            </div>

            <label>Código de verificación</label>
            <div class="captcha">S S B G Y 7</div>

            <input placeholder="Ingresa el código" class="form-control" />

            <button type="submit" class="btn btn-primary mt-2">Registrarse</button>

        </form>

        @* Añadido enlace para restablecer contraseña por si acaso en el registro *@
        <p>
            <a class="btn btn-link" href="/Account/ForgotPassword">¿Olvidaste tu contraseña?</a>
        </p>

    </div>

</body>
<script>
    (function(){
        var sel = document.getElementById('rolSelect');
        var lic = document.getElementById('licenciaWrapper');
        if(!sel) return;
        function toggle(){
            if(sel.value === 'Veterinario') lic.style.display = 'block'; else lic.style.display = 'none';
        }
        sel.addEventListener('change', toggle);
        toggle();
    })();
</script>
</html>