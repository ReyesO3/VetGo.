@model IEnumerable<VetGo.Models.Cita>

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Citas</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
            /* ===== GENERAL ===== */
            body {
                background-color: #f5f7fb;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                padding: 20px;
            }

            /* ===== BOTON CREAR ===== */
            p a {
                background-color: #4e7cf0;
                color: white;
                padding: 10px 15px;
                border-radius: 8px;
                text-decoration: none;
                font-weight: 500;
            }

                p a:hover {
                    background-color: #3b63c7;
                }

            /* ===== TABLA ===== */
            .table {
                width: 100%;
                border-collapse: collapse;
                background-color: white;
                border-radius: 12px;
                overflow: hidden;
                box-shadow: 0px 4px 10px rgba(0,0,0,0.08);
            }

                /* ENCABEZADO */
                .table thead {
                    background-color: #4e7cf0;
                    color: white;
                }

                    .table thead th {
                        padding: 12px;
                        text-align: left;
                        font-size: 14px;
                    }

                /* FILAS */
                .table tbody tr {
                    border-bottom: 1px solid #eee;
                    transition: background 0.2s;
                }

                    .table tbody tr:hover {
                        background-color: #f1f5ff;
                    }

                /* CELDAS */
                .table td {
                    padding: 12px;
                    font-size: 14px;
                    color: #333;
                }

                    /* ESTADO */
                    .table td:nth-child(3) {
                        font-weight: bold;
                        color: #28a745;
                    }

                /* ===== BOTONES ===== */
                .table a {
                    text-decoration: none;
                    font-size: 13px;
                    padding: 6px 10px;
                    border-radius: 6px;
                    margin-right: 5px;
                }

                    /* Editar */
                    .table a[href*="Edit"] {
                        background-color: #ffc107;
                        color: black;
                    }

                    /* Details */
                    .table a[href*="Details"] {
                        background-color: #17a2b8;
                        color: white;
                    }

                    /* Delete */
                    .table a[href*="Delete"] {
                        background-color: #dc3545;
                        color: white;
                    }

                    .table a:hover {
                        opacity: 0.85;
                    }

            /* ===== NAVBAR ===== */
            .navbar {
                background-color: #ffffff;
                border-bottom: 1px solid #e5e7eb;
                padding: 12px 30px;
                display: flex;
                align-items: center;
            }

            /* LOGO */
            .navbar-brand {
                font-size: 18px;
                color: #4e7cf0;
                display: flex;
                align-items: center;
                gap: 6px;
            }

            /* CONTENEDOR MENU */
            .navbar .ms-4 {
                display: flex;
                align-items: center;
            }

                /* LINKS */
                .navbar .ms-4 a {
                    color: #6b7280;
                    font-size: 14px;
                    margin-right: 22px;
                    text-decoration: none;
                    position: relative;
                    transition: all 0.3s ease;
                }

                    /* HOVER */
                    .navbar .ms-4 a:hover {
                        color: #4e7cf0;
                    }

                    /* LINK ACTIVO */
                    .navbar .ms-4 a.fw-bold {
                        color: #4e7cf0;
                        font-weight: 600;
                    }

                        /* LINEA DEBAJO ACTIVO */
                        .navbar .ms-4 a.fw-bold::after {
                            content: "";
                            position: absolute;
                            left: 0;
                            bottom: -8px;
                            width: 100%;
                            height: 2px;
                            background-color: #4e7cf0;
                            border-radius: 2px;
                        }

            /* BOTON */
            .navbar .btn {
                border-radius: 8px;
                padding: 6px 14px;
                font-size: 13px;
                transition: all 0.3s ease;
            }

            .btn-outline-secondary {
                border: 1px solid #d1d5db;
                color: #6b7280;
                background-color: white;
            }

                .btn-outline-secondary:hover {
                    background-color: #4e7cf0;
                    color: white;
                    border-color: #4e7cf0;
                }

            /* ESPACIADO AUTOMATICO */
            .ms-auto {
                margin-left: auto;
            }
    </style>

</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">VetGo</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Mascotas" asp-action="Index">Mascotas</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Citas" asp-action="Index">Cita</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="MensajesChats" asp-action="Index">Chat</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Historia_Clinica" asp-action="Index">Historial_Clinica</a>
                    </li>
                </ul>
                <button class="btn btn-outline-secondary ms-auto">Cerrar sesión</button>
            </div>
        </div>
    </nav>
    <p>
        <a asp-action="Create">+ Crear Nueva Cita</a>
    </p>

    <table class="table">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.Fecha)</th>
                <th>@Html.DisplayNameFor(model => model.Motivo)</th>
                <th>@Html.DisplayNameFor(model => model.Estado)</th>
                <th>@Html.DisplayNameFor(model => model.Mascota)</th>
                <th>@Html.DisplayNameFor(model => model.Veterinario)</th>
                <th>Acciones</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Fecha</td>
                    <td>@item.Motivo</td>
                    <td>@item.Estado</td>
                    <td>@item.Mascota</td>
                    <td>@item.Veterinario</td>

                    <td>
                        <a asp-action="Edit" asp-route-id="@item.IdCita">✏️ Editar</a>
                        <a asp-action="Details" asp-route-id="@item.IdCita">👁 Ver</a>
                        <a asp-action="Delete" asp-route-id="@item.IdCita">🗑 Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</body>
</html>
