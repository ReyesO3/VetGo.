@model IEnumerable<VetGo.Models.MensajesChat>

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Mensajes</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
    <style>

            body {
                background-color: #f5f7fb;
            }

            .navbar {
                background-color: white;
            }

            /* ===== GENERAL ===== */
            body {
                background-color: #f5f7fb;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                padding: 20px;
            }

            /* BOTÓN CREAR */
            p a {
                background-color: #4e7cf0;
                color: white;
                padding: 10px 15px;
                border-radius: 8px;
                text-decoration: none;
                font-weight: 500;
            }

                p a:hover {
                    background-color: #3b63c7;
                }

            /* ===== TABLA ===== */
            .table {
                width: 100%;
                border-collapse: collapse;
                background-color: white;
                border-radius: 12px;
                overflow: hidden;
                box-shadow: 0px 4px 10px rgba(0,0,0,0.08);
            }

                /* ENCABEZADO */
                .table thead {
                    background-color: #4e7cf0;
                    color: white;
                }

                    .table thead th {
                        padding: 12px;
                        text-align: left;
                        font-size: 13px;
                    }

                /* FILAS */
                .table tbody tr {
                    border-bottom: 1px solid #eee;
                    transition: 0.2s;
                }

                    .table tbody tr:hover {
                        background-color: #f1f5ff;
                    }

                /* CELDAS */
                .table td {
                    padding: 12px;
                    font-size: 13px;
                    color: #333;
                }

                    /* MENSAJE (contenido más visible) */
                    .table td:nth-child(4) {
                        max-width: 200px;
                        word-wrap: break-word;
                        font-weight: 500;
                    }

                    /* ESTADO LEIDO */
                    .table td:nth-child(6) {
                        font-weight: bold;
                        color: #28a745;
                    }

                /* ===== BOTONES ===== */
                .table a {
                    text-decoration: none;
                    font-size: 12px;
                    padding: 5px 8px;
                    border-radius: 6px;
                    margin-right: 5px;
                }

                    /* Editar */
                    .table a[href*="Edit"] {
                        background-color: #ffc107;
                        color: black;
                    }

                    /* Ver */
                    .table a[href*="Details"] {
                        background-color: #17a2b8;
                        color: white;
                    }

                    /* Eliminar */
                    .table a[href*="Delete"] {
                        background-color: #dc3545;
                        color: white;
                    }

                    .table a:hover {
                        opacity: 0.85;
                    }
    </style>

</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">VetGo</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Mascotas" asp-action="Index">Mascotas</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Citas" asp-action="Index">Cita</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="MensajesChats" asp-action="Index">Chat</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Historia_Clinica" asp-action="Index">Historial_Clinica</a>
                    </li>
                </ul>
                <button class="btn btn-outline-secondary ms-auto">Cerrar sesión</button>
            </div>
        </div>
    </nav>

    <div class="row">
        <div class="col-md-4">
            <h5>Contactos</h5>
            <ul id="contactsList" class="list-group"></ul>
        </div>
        <div class="col-md-8">
            <div id="chatPanel" style="border:1px solid #e5e7eb; border-radius:8px; padding:12px; background:white; min-height:400px; display:flex; flex-direction:column;">
                <div id="messages" style="flex:1; overflow:auto; margin-bottom:8px;"></div>
                <div style="display:flex; gap:8px;">
                    <input id="messageInput" class="form-control" placeholder="Escribe un mensaje..." />
                    <button id="sendBtn" class="btn btn-primary">Enviar</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        const currentUserId = @((ViewBag.CurrentUserId ?? 0));
        let selectedContactId = null;

        // SignalR connection
        const connection = new signalR.HubConnectionBuilder().withUrl('/chathub').build();
        connection.on('ReceiveMessage', (msg) => {
            const m = normalizeMessage(msg);
            // If the incoming message belongs to the currently open conversation, append it
            const container = document.getElementById('messages');
            if (!container) return;
            if ((m.idReceptor == currentUserId && m.idEmisor == selectedContactId) || (m.idEmisor == currentUserId && m.idReceptor == selectedContactId)) {
                const div = document.createElement('div');
                div.style.margin = '6px 0';
                div.textContent = (m.idEmisor === currentUserId ? 'Tú: ' : 'Contacto: ') + m.contenido;
                container.appendChild(div);
                container.scrollTop = container.scrollHeight;
            }
        });

        connection.start().then(() => {
            if (currentUserId && currentUserId > 0) {
                // join a group named after the current user's id so server can send to that group
                connection.invoke('JoinGroup', currentUserId.toString()).catch(e => console.error(e));
            }
        }).catch(e => console.error(e));

        // Leave group when unloading the page
        window.addEventListener('beforeunload', () => {
            try { if (currentUserId && currentUserId > 0) connection.invoke('LeaveGroup', currentUserId.toString()); } catch {}
        });

        async function loadContacts(){
            const res = await fetch('/MensajesChats/Contacts');
            const contacts = await res.json();
            const list = document.getElementById('contactsList');
            list.innerHTML = '';
            contacts.forEach(c => {
                const li = document.createElement('li');
                li.className = 'list-group-item';
                li.textContent = c.name + ' ('+c.email+')';
                li.style.cursor = 'pointer';
                li.onclick = () => { selectContact(c.id); };
                list.appendChild(li);
            });
        }

        async function selectContact(contactId){
            selectedContactId = contactId;
            const res = await fetch(`/MensajesChats/Conversation?userId=${currentUserId}&contactId=${contactId}`);
            const messages = await res.json();
            const container = document.getElementById('messages');
            container.innerHTML = '';
            messages.forEach(m => {
                const div = document.createElement('div');
                div.style.margin = '6px 0';
                div.textContent = (m.idEmisor === currentUserId ? 'Tú: ' : 'Contacto: ') + m.contenido;
                container.appendChild(div);
            });
            container.scrollTop = container.scrollHeight;
        }

        document.getElementById('sendBtn').addEventListener('click', async ()=>{
            const text = document.getElementById('messageInput').value.trim();
            if(!text || !selectedContactId) return;
            const payload = { IdEmisor: currentUserId, IdReceptor: selectedContactId, Contenido: text, TipoMensaje: 'texto', Leido:0, IdCita:0 };
            const res = await fetch('/MensajesChats/Send', { method:'POST', headers:{ 'Content-Type':'application/json' }, body: JSON.stringify(payload) });
            if(res.ok){
                document.getElementById('messageInput').value = '';
                selectContact(selectedContactId);
            }
        });

        // Inicializar
        loadContacts();
    </script>
    <script>
        // small helper to normalize property names returned from server
        function normalizeMessage(m){
            return {
                idMensaje: m.idMensaje || m.IdMensaje,
                idEmisor: m.idEmisor || m.IdEmisor,
                idReceptor: m.idReceptor || m.IdReceptor,
                contenido: m.contenido || m.Contenido,
                fechaEnvio: m.fechaEnvio || m.FechaEnvio
            };
        }
    </script>

</body>
</html>
